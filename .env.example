# ===========================================
# Livsplanlegg - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL_ROUTER=claude-sonnet-4-20250514
ANTHROPIC_MODEL_PLANNER=claude-opus-4-20250514

# --- Locale & Regional ---
NEXT_PUBLIC_DEFAULT_LOCALE=nb-NO
NEXT_PUBLIC_DEFAULT_TIMEZONE=Europe/Oslo
NEXT_PUBLIC_DEFAULT_CURRENCY=NOK

# --- Voice & Speech ---
STT_PROVIDER=browser
ENABLE_VOICE_TTS=true

# --- Feature Flags ---
ENABLE_AI_MEMORY=false
ENABLE_BROWSER_NOTIFICATIONS=false
